#!/usr/bin/env bash
# openrouter-agent — thin wrapper for counselors custom adapter
# Reads prompt from stdin, sends to OpenRouter API, prints response.
#
# Usage: echo "prompt" | openrouter-agent --model anthropic/claude-sonnet-4
# Requires: OPENROUTER_API_KEY in environment
#
# Install:
#   cp openrouter-agent ~/.local/bin/
#   chmod +x ~/.local/bin/openrouter-agent

set -euo pipefail

MODEL=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --model) MODEL="$2"; shift 2 ;;
    --model=*) MODEL="${1#--model=}"; shift ;;
    *) shift ;;
  esac
done

if [[ -z "$MODEL" ]]; then
  echo "Error: --model is required" >&2
  exit 1
fi

if [[ -z "${OPENROUTER_API_KEY:-}" ]]; then
  echo "Error: OPENROUTER_API_KEY not set" >&2
  exit 1
fi

# Read full prompt from stdin
PROMPT=$(cat)

if [[ -z "$PROMPT" ]]; then
  echo "Error: no prompt received on stdin" >&2
  exit 1
fi

# Escape prompt for JSON (handle newlines, quotes, backslashes, tabs)
PROMPT_ESCAPED=$(printf '%s' "$PROMPT" | python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))')

# Call OpenRouter (OpenAI-compatible endpoint)
RESPONSE=$(curl -s -w "\n%{http_code}" \
  "https://openrouter.ai/api/v1/chat/completions" \
  -H "Authorization: Bearer $OPENROUTER_API_KEY" \
  -H "Content-Type: application/json" \
  -H "X-Title: counselors" \
  -d "{
    \"model\": \"$MODEL\",
    \"messages\": [{\"role\": \"user\", \"content\": $PROMPT_ESCAPED}],
    \"max_tokens\": 16384
  }")

# Split response body from HTTP status code
HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [[ "$HTTP_CODE" -ne 200 ]]; then
  echo "Error: OpenRouter returned HTTP $HTTP_CODE" >&2
  echo "$BODY" >&2
  exit 1
fi

# Extract content from response
CONTENT=$(printf '%s' "$BODY" | python3 -c '
import sys, json
data = json.load(sys.stdin)
choices = data.get("choices", [])
if choices:
    print(choices[0].get("message", {}).get("content", ""))
else:
    print("Error: no choices in response", file=sys.stderr)
    sys.exit(1)
')

printf '%s\n' "$CONTENT"
